{
    "name": "Digital Tools",
    "image": "danchitnis/eedigits:latest",
    "remoteUser": "coder",
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.shellIntegration.enabled": true,
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    }
                }
            },
            "extensions": [
                "mshr-h.veriloghdl",
                "CHIPSAlliance.verible"
            ]
        }
    }
}