[options]
mode bmc
# Increased from 120: need to reach cycle_cnt == 115 for the rx_valid
# liveness assertion (rx_valid fires at cycle_cnt ≈ 101).
depth 150

[engines]
smtbmc yices

[script]
read -formal uart_full.v
read -formal uart_tx.v
read -formal uart_rx.v
read -formal uart_full_formal_v2.sv
prep -top uart_full_formal

[files]
uart_full.v
uart_tx.v
uart_rx.v
uart_full_formal_v2.sv
